# Leave blank when the backend serves the React build on the same domain.
# If you set this to another origin, the backend must use
# AUTH_COOKIE_SECURE=true and AUTH_COOKIE_SAME_SITE=none.
REACT_APP_API_URL=
# When true, keep the configured API URL even on localhost previews.
# Default false protects local testing from accidentally calling production APIs.
REACT_APP_FORCE_CONFIGURED_API=false

# Set to true only when you intentionally want the platform admin login visible.
REACT_APP_ENABLE_SUPER_ADMIN_LOGIN=false
